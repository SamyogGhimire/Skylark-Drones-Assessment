{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "client/dist"
      }
    },
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/client/dist/$1"
    }
  ],
  "env": {
    "MONDAY_API_KEY": "@MONDAY_API_KEY",
    "DEALS_BOARD_ID": "@DEALS_BOARD_ID",
    "WORK_ORDERS_BOARD_ID": "@WORK_ORDERS_BOARD_ID",
    "GROQ_API_KEY": "@GROQ_API_KEY"
  }
}
